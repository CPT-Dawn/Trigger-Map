{
  "expo": {
    "name": "TriggerMap",
    "slug": "TriggerMap",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "android": {
      "package": "com.cptdawn.triggermap",
      "versionCode": 1,
      "allowBackup": false,
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true
        }
      ]
    ],
    "scheme": "triggermap",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7739e491-6d7a-4b66-8aa7-e15bcc1fb26b"
      }
    }
  }
}
